generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Plain Node.js maintenance scripts currently consume this packaged client.
generator scriptClient {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ShopMembershipRole {
  OWNER
  ADMIN
  STAFF
}

enum MarketingLeadSource {
  CONTACT
  APPOINTMENT
  DROP_OFF
}

enum MarketingLeadStatus {
  NEW
  CONTACTED
  SCHEDULED
  CONVERTED
  CLOSED
}

model Shop {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  addressLine1          String?               @map("address_line1")
  city                  String?
  state                 String?
  postalCode            String?               @map("postal_code")
  phone                 String?
  defaultTaxRate        Decimal               @default(0) @map("default_tax_rate") @db.Decimal(6, 3)
  defaultLaborRate      Decimal               @default(0) @map("default_labor_rate") @db.Decimal(12, 2)
  partsTaxable          Boolean               @default(true) @map("parts_taxable")
  laborTaxable          Boolean               @default(false) @map("labor_taxable")
  invoiceFooterMessage  String?               @map("invoice_footer_message")
  warrantyText          String?               @map("warranty_text")
  nextRepairOrderNumber Int                   @default(1) @map("next_repair_order_number")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @default(now()) @updatedAt @map("updated_at")
  customers             Customer[]
  vehicles              Vehicle[]
  repairOrders          RepairOrder[]
  repairOrderParts      RepairOrderPart[]
  repairOrderLabor      RepairOrderLabor[]
  invoices              Invoice[]
  invoiceParts          InvoicePart[]
  invoiceLabor          InvoiceLabor[]
  payments              Payment[]
  accountsReceivable    AccountReceivable[]
  employees             Employee[]
  memberships           ShopMembership[]
  rawLegacyCustomers    RawLegacyCustomer[]
  rawLegacyVehicles     RawLegacyVehicle[]
  rawLegacyFinal        RawLegacyFinal[]
  rawLegacyLaborFinal   RawLegacyLaborFinal[]
  rawLegacyAr           RawLegacyAr[]
  rawLegacyOrderParts   RawLegacyOrderPart[]
  rawLegacyOrderLabor   RawLegacyOrderLabor[]
  legacyImportRuns      LegacyImportRun[]
  legacyImportErrors    LegacyImportError[]
  cannedServices        CannedService[]
  auditLogs             AuditLog[]
  staffInvites          StaffInvite[]
  marketingLeads        MarketingLead[]

  @@map("shops")
}

model MarketingLead {
  id               String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId           String              @map("shop_id") @db.Uuid
  source           MarketingLeadSource
  name             String
  phone            String?
  email            String?
  vehicleYear      Int?                @map("vehicle_year")
  vehicleMake      String?             @map("vehicle_make")
  vehicleModel     String?             @map("vehicle_model")
  requestedService String?             @map("requested_service")
  preferredDate    DateTime?           @map("preferred_date") @db.Date
  message          String?
  status           MarketingLeadStatus @default(NEW)
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @default(now()) @updatedAt @map("updated_at")
  shop             Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, status, createdAt])
  @@map("marketing_leads")
}

model CannedService {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId           String   @map("shop_id") @db.Uuid
  name             String
  description      String
  defaultHours     Decimal  @default(1) @map("default_hours") @db.Decimal(8, 2)
  defaultLaborRate Decimal  @default(0) @map("default_labor_rate") @db.Decimal(12, 2)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")
  shop             Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, name])
  @@index([shopId, active])
  @@map("canned_services")
}

model AuditLog {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId         String   @map("shop_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  action         String
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id") @db.Uuid
  actorEmail     String?  @map("actor_email")
  actorRole      String?  @map("actor_role")
  entityLabel    String?  @map("entity_label")
  entityHref     String?  @map("entity_href")
  contextSummary String?  @map("context_summary")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  shop           Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@index([shopId, entityType, entityId])
  @@map("audit_logs")
}

model StaffInvite {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId          String             @map("shop_id") @db.Uuid
  email           String
  role            ShopMembershipRole @default(STAFF)
  status          String             @default("pending")
  invitedByUserId String?            @map("invited_by_user_id") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @default(now()) @updatedAt @map("updated_at")
  shop            Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, email])
  @@index([shopId, status])
  @@map("staff_invites")
}

model ShopMembership {
  id        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId    String             @map("shop_id") @db.Uuid
  userId    String             @map("user_id") @db.Uuid
  userEmail String?            @map("user_email")
  role      ShopMembershipRole @default(STAFF)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @default(now()) @updatedAt @map("updated_at")
  shop      Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, userId])
  @@index([userId])
  @@map("shop_memberships")
}

model Customer {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId             String              @map("shop_id") @db.Uuid
  displayName        String              @map("display_name")
  email              String?
  phone              String?
  phone2             String?
  addressLine1       String?             @map("address_line1")
  addressLine2       String?             @map("address_line2")
  city               String?
  state              String?
  postalCode         String?             @map("postal_code")
  notes              String?
  message            String?
  legacyCustno       String?             @map("legacy_custno")
  legacySourceTable  String?             @map("legacy_source_table")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at")
  shop               Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  vehicles           Vehicle[]
  repairOrders       RepairOrder[]
  invoices           Invoice[]
  payments           Payment[]
  accountsReceivable AccountReceivable[]

  @@unique([shopId, legacyCustno])
  @@index([legacyCustno])
  @@index([shopId, displayName])
  @@map("customers")
}

model Vehicle {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String        @map("shop_id") @db.Uuid
  customerId        String        @map("customer_id") @db.Uuid
  year              Int?
  make              String?
  model             String?
  engine            String?
  vin               String?
  licensePlate      String?       @map("license_plate")
  odometer          Int?
  notes             String?
  message           String?
  legacyCarno       String?       @map("legacy_carno")
  legacySourceTable String?       @map("legacy_source_table")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at")
  shop              Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer          Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  repairOrders      RepairOrder[]
  invoices          Invoice[]

  @@unique([shopId, legacyCarno])
  @@index([legacyCarno])
  @@index([shopId, customerId])
  @@index([shopId, vin])
  @@index([shopId, licensePlate])
  @@map("vehicles")
}

model RepairOrder {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId             String             @map("shop_id") @db.Uuid
  customerId         String             @map("customer_id") @db.Uuid
  vehicleId          String             @map("vehicle_id") @db.Uuid
  assignedEmployeeId String?            @map("assigned_employee_id") @db.Uuid
  status             String             @default("draft")
  openedAt           DateTime           @default(now()) @map("opened_at")
  closedAt           DateTime?          @map("closed_at")
  odometer           Int?
  concern            String?
  notes              String?
  partsTotal         Decimal            @default(0) @map("parts_total") @db.Decimal(12, 2)
  laborTotal         Decimal            @default(0) @map("labor_total") @db.Decimal(12, 2)
  taxTotal           Decimal            @default(0) @map("tax_total") @db.Decimal(12, 2)
  estimatedTotal     Decimal            @default(0) @map("estimated_total") @db.Decimal(12, 2)
  repairOrderNumber  Int?               @map("repair_order_number")
  legacyRoNo         String?            @map("legacy_ro_no")
  legacySourceTable  String?            @map("legacy_source_table")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at")
  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer           Customer           @relation(fields: [customerId], references: [id])
  vehicle            Vehicle            @relation(fields: [vehicleId], references: [id])
  assignedEmployee   Employee?          @relation(fields: [assignedEmployeeId], references: [id])
  parts              RepairOrderPart[]
  labor              RepairOrderLabor[]
  invoices           Invoice[]

  @@unique([shopId, legacyRoNo])
  @@unique([shopId, repairOrderNumber])
  @@index([legacyRoNo])
  @@index([shopId, status])
  @@index([customerId])
  @@index([vehicleId])
  @@map("repair_orders")
}

model RepairOrderPart {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String      @map("shop_id") @db.Uuid
  repairOrderId     String      @map("repair_order_id") @db.Uuid
  description       String
  partNumber        String?     @map("part_number")
  quantity          Decimal     @default(1) @db.Decimal(10, 2)
  unitPrice         Decimal     @default(0) @map("unit_price") @db.Decimal(12, 2)
  legacyLineKey     String      @map("legacy_line_key")
  legacyRoNo        String?     @map("legacy_ro_no")
  legacySourceTable String?     @map("legacy_source_table")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @default(now()) @updatedAt @map("updated_at")
  shop              Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairOrder       RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)

  @@unique([shopId, legacyLineKey])
  @@index([repairOrderId])
  @@index([shopId, legacyRoNo])
  @@map("repair_order_parts")
}

model RepairOrderLabor {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String      @map("shop_id") @db.Uuid
  repairOrderId     String      @map("repair_order_id") @db.Uuid
  description       String
  hours             Decimal     @default(0) @db.Decimal(8, 2)
  hourlyRate        Decimal     @default(0) @map("hourly_rate") @db.Decimal(12, 2)
  legacyLineKey     String      @map("legacy_line_key")
  legacyRoNo        String?     @map("legacy_ro_no")
  legacySourceTable String?     @map("legacy_source_table")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @default(now()) @updatedAt @map("updated_at")
  shop              Shop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairOrder       RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)

  @@unique([shopId, legacyLineKey])
  @@index([repairOrderId])
  @@index([shopId, legacyRoNo])
  @@map("repair_order_labor")
}

model Invoice {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId             String              @map("shop_id") @db.Uuid
  repairOrderId      String?             @map("repair_order_id") @db.Uuid
  customerId         String              @map("customer_id") @db.Uuid
  vehicleId          String?             @map("vehicle_id") @db.Uuid
  status             String              @default("draft")
  invoiceDate        DateTime?           @map("invoice_date")
  dueAt              DateTime?           @map("due_at")
  partsTotal         Decimal             @default(0) @map("parts_total") @db.Decimal(12, 2)
  laborTotal         Decimal             @default(0) @map("labor_total") @db.Decimal(12, 2)
  subtotal           Decimal             @default(0) @db.Decimal(12, 2)
  taxTotal           Decimal             @default(0) @map("tax_total") @db.Decimal(12, 2)
  total              Decimal             @default(0) @db.Decimal(12, 2)
  paidTotal          Decimal             @default(0) @map("paid_total") @db.Decimal(12, 2)
  repairOrderNumber  Int?                @map("repair_order_number")
  shopSnapshot       Json?               @map("shop_snapshot")
  customerSnapshot   Json?               @map("customer_snapshot")
  vehicleSnapshot    Json?               @map("vehicle_snapshot")
  legacyRoNo         String?             @map("legacy_ro_no")
  legacySourceTable  String?             @map("legacy_source_table")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at")
  shop               Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairOrder        RepairOrder?        @relation(fields: [repairOrderId], references: [id])
  customer           Customer            @relation(fields: [customerId], references: [id])
  vehicle            Vehicle?            @relation(fields: [vehicleId], references: [id])
  parts              InvoicePart[]
  labor              InvoiceLabor[]
  payments           Payment[]
  accountsReceivable AccountReceivable[]

  @@unique([shopId, legacyRoNo])
  @@unique([repairOrderId])
  @@unique([shopId, repairOrderNumber])
  @@index([legacyRoNo])
  @@index([shopId, invoiceDate])
  @@index([shopId, status])
  @@index([customerId])
  @@map("invoices")
}

model InvoicePart {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String   @map("shop_id") @db.Uuid
  invoiceId         String   @map("invoice_id") @db.Uuid
  description       String
  partNumber        String?  @map("part_number")
  quantity          Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice         Decimal  @default(0) @map("unit_price") @db.Decimal(12, 2)
  legacyLineKey     String   @map("legacy_line_key")
  legacyRoNo        String?  @map("legacy_ro_no")
  legacySourceTable String?  @map("legacy_source_table")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  invoice           Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([shopId, legacyLineKey])
  @@index([invoiceId])
  @@index([shopId, legacyRoNo])
  @@map("invoice_parts")
}

model InvoiceLabor {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String   @map("shop_id") @db.Uuid
  invoiceId         String   @map("invoice_id") @db.Uuid
  description       String
  hours             Decimal  @default(0) @db.Decimal(8, 2)
  hourlyRate        Decimal  @default(0) @map("hourly_rate") @db.Decimal(12, 2)
  legacyLineKey     String   @map("legacy_line_key")
  legacyRoNo        String?  @map("legacy_ro_no")
  legacySourceTable String?  @map("legacy_source_table")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")
  shop              Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  invoice           Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([shopId, legacyLineKey])
  @@index([invoiceId])
  @@index([shopId, legacyRoNo])
  @@map("invoice_labor")
}

model Payment {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String    @map("shop_id") @db.Uuid
  invoiceId         String?   @map("invoice_id") @db.Uuid
  customerId        String?   @map("customer_id") @db.Uuid
  amount            Decimal   @db.Decimal(12, 2)
  method            String?
  paidAt            DateTime  @default(now()) @map("paid_at")
  reference         String?
  legacyRoNo        String?   @map("legacy_ro_no")
  legacySourceTable String?   @map("legacy_source_table")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")
  shop              Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  invoice           Invoice?  @relation(fields: [invoiceId], references: [id])
  customer          Customer? @relation(fields: [customerId], references: [id])

  @@index([shopId, paidAt])
  @@index([invoiceId])
  @@index([shopId, legacyRoNo])
  @@map("payments")
}

model AccountReceivable {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String    @map("shop_id") @db.Uuid
  invoiceId         String?   @map("invoice_id") @db.Uuid
  customerId        String    @map("customer_id") @db.Uuid
  balance           Decimal   @default(0) @db.Decimal(12, 2)
  dueAt             DateTime? @map("due_at")
  status            String    @default("open")
  legacyRoNo        String?   @map("legacy_ro_no")
  legacySourceTable String?   @map("legacy_source_table")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")
  shop              Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  invoice           Invoice?  @relation(fields: [invoiceId], references: [id])
  customer          Customer  @relation(fields: [customerId], references: [id])

  @@unique([shopId, legacyRoNo])
  @@unique([invoiceId])
  @@index([shopId, status])
  @@index([customerId])
  @@index([shopId, legacyRoNo])
  @@index([legacyRoNo])
  @@map("accounts_receivable")
}

model Employee {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String        @map("shop_id") @db.Uuid
  displayName       String        @map("display_name")
  email             String?
  role              String        @default("staff")
  active            Boolean       @default(true)
  legacySourceTable String?       @map("legacy_source_table")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at")
  shop              Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  repairOrders      RepairOrder[]

  @@unique([shopId, email])
  @@index([shopId, active])
  @@map("employees")
}

model LegacyImportRun {
  id               String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId           String                @map("shop_id") @db.Uuid
  status           String                @default("pending")
  sourceLabel      String                @map("source_label")
  startedAt        DateTime?             @map("started_at")
  completedAt      DateTime?             @map("completed_at")
  recordsProcessed Int                   @default(0) @map("records_processed")
  recordsImported  Int                   @default(0) @map("records_imported")
  recordsFailed    Int                   @default(0) @map("records_failed")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @default(now()) @updatedAt @map("updated_at")
  shop             Shop                  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  errors           LegacyImportError[]
  rawCustomers     RawLegacyCustomer[]
  rawVehicles      RawLegacyVehicle[]
  rawFinal         RawLegacyFinal[]
  rawLaborFinal    RawLegacyLaborFinal[]
  rawAr            RawLegacyAr[]
  rawOrderParts    RawLegacyOrderPart[]
  rawOrderLabor    RawLegacyOrderLabor[]

  @@index([shopId, createdAt])
  @@map("legacy_import_runs")
}

model RawLegacyCustomer {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String          @map("shop_id") @db.Uuid
  legacyImportRunId String          @map("legacy_import_run_id") @db.Uuid
  legacyCustno      String?         @map("legacy_custno")
  rawData           Json            @map("raw_data")
  createdAt         DateTime        @default(now()) @map("created_at")
  shop              Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  importRun         LegacyImportRun @relation(fields: [legacyImportRunId], references: [id], onDelete: Cascade)

  @@index([shopId, legacyCustno])
  @@index([legacyImportRunId])
  @@map("raw_legacy_customers")
}

model RawLegacyVehicle {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String          @map("shop_id") @db.Uuid
  legacyImportRunId String          @map("legacy_import_run_id") @db.Uuid
  legacyCustno      String?         @map("legacy_custno")
  legacyCarno       String?         @map("legacy_carno")
  rawData           Json            @map("raw_data")
  createdAt         DateTime        @default(now()) @map("created_at")
  shop              Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  importRun         LegacyImportRun @relation(fields: [legacyImportRunId], references: [id], onDelete: Cascade)

  @@index([shopId, legacyCustno])
  @@index([shopId, legacyCarno])
  @@index([legacyImportRunId])
  @@map("raw_legacy_vehicles")
}

model RawLegacyFinal {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String          @map("shop_id") @db.Uuid
  legacyImportRunId String          @map("legacy_import_run_id") @db.Uuid
  legacyRoNo        String?         @map("legacy_ro_no")
  legacyCustno      String?         @map("legacy_custno")
  legacyCarno       String?         @map("legacy_carno")
  rawData           Json            @map("raw_data")
  createdAt         DateTime        @default(now()) @map("created_at")
  shop              Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  importRun         LegacyImportRun @relation(fields: [legacyImportRunId], references: [id], onDelete: Cascade)

  @@index([shopId, legacyRoNo])
  @@index([shopId, legacyCustno])
  @@index([legacyImportRunId])
  @@map("raw_legacy_final")
}

model RawLegacyLaborFinal {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String          @map("shop_id") @db.Uuid
  legacyImportRunId String          @map("legacy_import_run_id") @db.Uuid
  legacyRoNo        String?         @map("legacy_ro_no")
  legacyCustno      String?         @map("legacy_custno")
  legacyCarno       String?         @map("legacy_carno")
  rawData           Json            @map("raw_data")
  createdAt         DateTime        @default(now()) @map("created_at")
  shop              Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  importRun         LegacyImportRun @relation(fields: [legacyImportRunId], references: [id], onDelete: Cascade)

  @@index([shopId, legacyRoNo])
  @@index([shopId, legacyCustno])
  @@index([legacyImportRunId])
  @@map("raw_legacy_labor_final")
}

model RawLegacyAr {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId            String          @map("shop_id") @db.Uuid
  legacyImportRunId String          @map("legacy_import_run_id") @db.Uuid
  legacyRoNo        String?         @map("legacy_ro_no")
  legacyCustno      String?         @map("legacy_custno")
