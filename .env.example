# Supabase Postgres pooled connection (application runtime)
DATABASE_URL="postgresql://postgres.example:password@example.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Postgres direct connection (reserved for migration workflows)
DIRECT_URL="postgresql://postgres.example:password@example.supabase.co:5432/postgres"

# Supabase project API settings
NEXT_PUBLIC_SUPABASE_URL="https://example-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="example-anon-key"
SUPABASE_SERVICE_ROLE_KEY="example-service-role-key"

# Operator-only client setup inputs (CLI arguments may be used instead)
PLUMWORKS_SHOP_NAME="Example Repair"
PLUMWORKS_SHOP_ADDRESS="100 Example Street"
PLUMWORKS_SHOP_CITY="Example City"
PLUMWORKS_SHOP_STATE="MI"
PLUMWORKS_SHOP_POSTAL_CODE="00000"
PLUMWORKS_SHOP_PHONE="000-000-0000"
PLUMWORKS_OWNER_EMAIL="owner@example.invalid"
PLUMWORKS_SHOP_SLUG="example-repair"

# Optional explicit selector for maintenance scripts in a multi-shop database
PLUMWORKS_SHOP_ID="00000000-0000-4000-8000-000000000000"
