{
  "name": "plumworks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "node --env-file=.env.local ./node_modules/prisma/build/index.js generate",
    "prisma:validate": "node --env-file=.env.local ./node_modules/prisma/build/index.js validate",
    "prisma:migrate:deploy": "node --env-file=.env.local ./node_modules/prisma/build/index.js migrate deploy",
    "client:setup": "node --env-file=.env.local scripts/setup-client.mjs",
    "marketing:import": "node --env-file=.env.local scripts/import-marketing-content.mjs",
    "db:seed": "node --env-file=.env.local prisma/seed.mjs",
    "legacy:import:customers-vehicles": "node --env-file=.env.local scripts/import-customers-vehicles.mjs",
    "legacy:transform:customers-vehicles": "node --env-file=.env.local scripts/transform-customers-vehicles.mjs",
    "legacy:customers:recover": "node --env-file=.env.local scripts/recover-legacy-customers.mjs",
    "legacy:import:invoices": "node --env-file=.env.local scripts/import-invoices.mjs",
    "legacy:transform:invoices": "node --env-file=.env.local scripts/transform-invoices.mjs",
    "legacy:payments:import": "node --env-file=.env.local scripts/import-legacy-payments.mjs",
    "cleanup:test-ro": "node --env-file=.env.local scripts/cleanup-test-repair-order.mjs",
    "legacy:import:open-orders": "node --env-file=.env.local scripts/import-open-orders.mjs",
    "legacy:transform:open-orders": "node --env-file=.env.local scripts/transform-open-orders.mjs",
    "legacy:cutover:dry-run": "node --env-file=.env.local scripts/legacy-cutover.mjs --dry-run",
    "legacy:cutover:backup": "node --env-file=.env.local scripts/legacy-cutover.mjs --backup --report",
    "legacy:cutover:verify": "node --env-file=.env.local scripts/legacy-cutover.mjs --verify --report",
    "verify:branding": "node scripts/verify-software-branding.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.12.1",
    "@supabase/supabase-js": "^2.110.3",
    "mermaid": "^11.16.0",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
